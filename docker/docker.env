# ArduPilot source branch to clone and build inside the container.
# Change this to switch to a different Copter release.
ARDUPILOT_CLONE_BRANCH=Copter-4.6.3

# UDP port that QGroundControl (running on the host) listens on.
MAVLINK_GCS_PORT=14550

# UDP port that pymavlink scripts (running inside the container) connect to.
MAVLINK_SCRIPT_PORT=14551
